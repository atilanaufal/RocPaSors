    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\Images\LogoClear.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="MainWindow - Copy.xaml.cs" />
